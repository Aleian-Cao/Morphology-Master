rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidAnalysis() {
      let data = request.resource.data;
      return data.keys().hasAll(['word', 'userId', 'createdAt']) &&
             data.word is string && data.word.size() > 0 && data.word.size() < 100 &&
             data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidAnalysis();
      allow update: if false; // Immutable
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /public_lessons/{lessonId} {
      allow read: if true; // Publicly readable
      allow create: if request.resource.data.keys().hasAll(['id', 'root', 'meaning', 'category', 'tier']);
      allow update: if false; // Immutable once created
      allow delete: if false;
    }

    match /public_assessments/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    match /pro_keys/{keyId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && request.auth.token.email == "10a10caonguyenthanhan@gmail.com";
      allow create: if isAuthenticated() && request.auth.token.email == "10a10caonguyenthanhan@gmail.com";
      allow update: if isAuthenticated() && resource.data.used == false && request.resource.data.used == true;
      allow delete: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if true; // Protected by UI password
    }
  }
}
