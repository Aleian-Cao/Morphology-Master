{
  "entities": {
    "MorphologyAnalysis": {
      "title": "Morphology Analysis",
      "description": "A saved morphology analysis of a word.",
      "type": "object",
      "properties": {
        "word": {
          "type": "string",
          "description": "The word analyzed."
        },
        "phonetic": {
          "type": "string",
          "description": "The phonetic transcription."
        },
        "meaning_vi": {
          "type": "string",
          "description": "The Vietnamese meaning."
        },
        "explanation_vi": {
          "type": "string",
          "description": "A detailed explanation in Vietnamese of how the parts form the meaning."
        },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "type": { "type": "string" },
              "meaning": { "type": "string" },
              "meaning_vi": { "type": "string" }
            }
          }
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "morphologicalRelatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this analysis."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the analysis was saved."
        }
      },
      "required": ["word", "userId", "createdAt"]
    },
    "PublicLesson": {
      "title": "Public Lesson",
      "description": "A cached, AI-generated lesson shared publicly.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "root": { "type": "string" },
        "tier": { "type": "number" },
        "category": { "type": "string" },
        "meaning": { "type": "string" },
        "phonetic": { "type": "string" },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "type": { "type": "string" },
              "meaning": { "type": "string" }
            }
          }
        },
        "derivatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metaphor": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "root", "meaning", "category", "tier"]
    }
  },
  "firestore": {
    "/analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/MorphologyAnalysis" },
      "description": "Saved morphology analyses."
    },
    "/public_lessons/{lessonId}": {
      "schema": { "$ref": "#/entities/PublicLesson" },
      "description": "Publicly shared, AI-generated lessons."
    }
  }
}
